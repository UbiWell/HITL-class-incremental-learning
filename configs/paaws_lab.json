{
  "_comment": "PAAWS Lab dataset configuration for HITL-HAR. This is the worked example. Copy and adapt for your own dataset.",

  "dataset": {
    "name": "paaws_lab",
    "dim": 8,
    "sampling_rate_hz": 20,
    "stream_names": [
      "LeftAnkle",
      "LeftThigh",
      "LeftWaist",
      "LeftWrist",
      "RightAnkle",
      "RightThigh",
      "RightWaist",
      "RightWrist"
    ]
  },

  "preprocessing": {
    "source_fs": 20,
    "target_fs": 20,
    "window_size_samples": 100,
    "window_overlap": 0.5,
    "channel_order": ["acc_x", "acc_y", "acc_z"],
    "normalization": "zscore"
  },

  "encoders": {
    "_comment": "Map each stream to an encoder. All streams may share one encoder, or some may use a specialist encoder (e.g. wrist-specific). Each entry needs: path (to .pt file), input_shape [T, C], embed_dim.",
    "default": {
      "path": "./models/20260320-130313_simclr.pt",
      "input_shape": [100, 3],
      "embed_dim": 96
    }
  },
  "stream_to_encoder": {
    "_comment": "Map stream name -> encoder key above. All streams use 'default' here.",
    "LeftAnkle":  "default",
    "LeftThigh":  "default",
    "LeftWaist":  "default",
    "LeftWrist":  "default",
    "RightAnkle": "default",
    "RightThigh": "default",
    "RightWaist": "default",
    "RightWrist": "default"
  },

  "seed_activities": [
    "Walking",
    "Sitting_Still",
    "Standing_Still",
    "Cycling_Active_Pedaling_Regular_Bicycle"
  ],

  "training_exclusions": {
    "_comment": "Used during training to exclude co-occurring activities from the negative set of a head. Does NOT affect co-occurrence detection at runtime. Key = activity being trained; value = list of activities excluded from negatives.",
    "Walking":                                      [],
    "Sitting_Still":                                [],
    "Standing_Still":                               [],
    "Cycling_Active_Pedaling_Regular_Bicycle":      [],
    "Treadmill_2mph_Lab":                           ["Walking"],
    "Treadmill_3mph_Free_Walk_Lab":                 ["Walking"],
    "Treadmill_3mph_Hands_Pockets_Lab":             ["Walking"],
    "Treadmill_3mph_Conversation_Lab":              ["Walking"],
    "Treadmill_3mph_Phone_Lab":                     ["Walking"],
    "Treadmill_3mph_Drink_Lab":                     ["Walking"],
    "Treadmill_3mph_Briefcase_Lab":                 ["Walking"],
    "Treadmill_4mph_Lab":                           ["Walking"],
    "Treadmill_5_5mph_Lab":                         ["Walking"],
    "Walking_Up_Stairs":                            ["Walking"],
    "Walking_Down_Stairs":                          ["Walking"],
    "Sitting_With_Movement":                        ["Sitting_Still"],
    "Sit_Recline_Talk_Lab":                         ["Sitting_Still", "Sitting_With_Movement"],
    "Sit_Recline_Web_Browse_Lab":                   ["Sitting_Still", "Sitting_With_Movement"],
    "Sit_Typing_Lab":                               ["Sitting_Still", "Sitting_With_Movement"],
    "Sit_Writing_Lab":                              ["Sitting_Still", "Sitting_With_Movement"],
    "Machine_Chest_Press_Lab":                      ["Sitting_Still", "Sitting_With_Movement"],
    "Machine_Leg_Press_Lab":                        ["Sitting_Still", "Sitting_With_Movement"],
    "Standing_With_Movement":                       [],
    "Stand_Conversation_Lab":                       ["Standing_Still", "Standing_With_Movement"],
    "Stand_Shelf_Load_Lab":                         ["Standing_Still", "Standing_With_Movement"],
    "Stand_Shelf_Unload_Lab":                       ["Standing_Still", "Standing_With_Movement"],
    "Organizing_Shelf_Cabinet":                     ["Standing_Still", "Standing_With_Movement"],
    "Arm_Curls_Lab":                                ["Standing_Still", "Standing_With_Movement"],
    "Chopping_Food_Lab":                            ["Standing_Still", "Standing_With_Movement"],
    "Folding_Clothes":                              ["Standing_Still"],
    "Washing_Dishes_Lab":                           ["Standing_Still"],
    "Sweeping":                                     ["Walking", "Standing_With_Movement"],
    "Vacuuming":                                    ["Walking", "Standing_With_Movement"],
    "Playing_Frisbee":                              ["Walking", "Standing_With_Movement"],
    "Stationary_Biking_300_Lab":                    ["Cycling_Active_Pedaling_Regular_Bicycle"],
    "Lying_On_Back_Lab":                            [],
    "Lying_On_Left_Side_Lab":                       [],
    "Lying_On_Right_Side_Lab":                      [],
    "Lying_On_Stomach_Lab":                         [],
    "Ab_Crunches_Lab":                              [],
    "Push_Up_Lab":                                  []
  },

  "cooccurrence_graph": {
    "_comment": "Ground-truth co-occurrence relationships used to evaluate the human-in-the-loop simulation. Key = activity; value = list of existing trained activities that are expected to co-occur with it (i.e. should fire). This is separate from training_exclusions.",
    "Walking":                                      [],
    "Sitting_Still":                                [],
    "Standing_Still":                               [],
