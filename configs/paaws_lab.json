    "Lying_On_Right_Side_Lab":                      [],
    "Lying_On_Stomach_Lab":                         [],
    "Ab_Crunches_Lab":                              [],
    "Push_Up_Lab":                                  []
  },

  "mutual_exclusions": {
    "_comment": "Pairs of activities that cannot occur simultaneously. Stored as a dict of activity -> [list of mutually exclusive activities]. The registry builds symmetric rules from this.",
    "Walking":                 ["Sitting_Still", "Standing_Still", "Lying_On_Back_Lab", "Lying_On_Left_Side_Lab", "Lying_On_Right_Side_Lab", "Lying_On_Stomach_Lab"],
    "Sitting_Still":           ["Walking", "Standing_Still", "Lying_On_Back_Lab", "Lying_On_Left_Side_Lab", "Lying_On_Right_Side_Lab", "Lying_On_Stomach_Lab"],
    "Standing_Still":          ["Walking", "Sitting_Still", "Lying_On_Back_Lab", "Lying_On_Left_Side_Lab", "Lying_On_Right_Side_Lab", "Lying_On_Stomach_Lab"],
    "Lying_On_Back_Lab":       ["Walking", "Sitting_Still", "Standing_Still"],
    "Lying_On_Left_Side_Lab":  ["Walking", "Sitting_Still", "Standing_Still"],
    "Lying_On_Right_Side_Lab": ["Walking", "Sitting_Still", "Standing_Still"],
    "Lying_On_Stomach_Lab":    ["Walking", "Sitting_Still", "Standing_Still"]
  },

  "ambiguous_cooccurrence": {
    "_comment": "Activities where co-occurrence detection is unreliable (e.g. subtle signal overlap). Retraining for missed co-occurrences is skipped for these.",
    "activities": []
  },

  "sensor_hints": {
    "_comment": "Per-activity sensor gating weights, one float per stream (in stream_names order). 1.0 = fully relevant, 0.5 = partial, 0.0 = irrelevant. Falls back to uniform_hint if activity not listed.",
    "uniform_hint": [0.5, 0.5, 0.5, 0.5, 0.5, 0.5, 0.5, 0.5],
    "hints": {
      "Walking":                                     [1.0, 0.5, 0.5, 0.0, 1.0, 0.5, 0.5, 0.0],
